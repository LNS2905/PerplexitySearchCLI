# Path to local pi-perplexity checkout (required unless --upstream is passed)
# PI_PERPLEXITY_UPSTREAM_DIR=/path/to/pi-perplexity

# Skip macOS desktop app token extraction, go straight to email OTP
# PI_AUTH_NO_BORROW=1

# Pre-fill email for OTP login (useful for non-interactive setups)
# PI_PERPLEXITY_EMAIL=you@example.com

# Pre-fill OTP code (useful for non-interactive setups)
# PI_PERPLEXITY_OTP=123456
